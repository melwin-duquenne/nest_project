# =============================================================
#  TaskFlow API — Variables d'environnement
#  Copiez ce fichier : cp .env.example .env
#  puis remplissez les valeurs marquées <CHANGER>
# =============================================================

# ----- Environnement -----
NODE_ENV=development          # development | production | test

# ----- Serveur -----
PORT=3000                     # Port d'écoute de l'API

# ----- Base de données PostgreSQL -----
# Si vous utilisez Docker : lancez "docker compose up -d postgres"
# La base, l'utilisateur et le mot de passe seront créés automatiquement.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=<CHANGER>         # Mot de passe PostgreSQL (obligatoire)

# URL complète utilisée par Prisma et les migrations TypeORM
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ----- Authentification JWT -----
# Générer un secret fort : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CHANGER>          # Clé secrète JWT (obligatoire, min. 32 caractères)
JWT_EXPIRES_IN=1h             # Durée de validité du token (ex : 1h, 24h, 7d)
